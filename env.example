# Walmart Marketplace API (Seller Center -> Developer Portal -> API Keys)
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=

# Notion internal integration token (notion.so/my-integrations)
# After creating it, connect it to BOTH databases:
# open each database -> ... menu -> Connections -> add your integration
NOTION_TOKEN=

# Database IDs (already filled in for your workspace)
NOTION_ORDERS_DB=a794e5214fa249029099bcb910cf2bd5
NOTION_INVENTORY_DB=c116689d42fb481f9fd14316785e61f3

# Brevo transactional email
BREVO_API_KEY=
DIGEST_FROM_EMAIL=
DIGEST_TO_EMAIL=

# Inventory: qty at or below this = Low Stock (per-SKU override: edit Reorder Point in Notion, it's preserved)
REORDER_POINT_DEFAULT=5
